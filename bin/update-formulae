#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "json"
require "open3"

ROOT = File.expand_path("..", __dir__)

PROJECTS = [
  {
    name: "wpdiff",
    class_name: "Wpdiff",
    repo: "almeidx/wpdiff",
    desc: "Diff locally installed WordPress plugins against their upstream versions"
  },
  {
    name: "uatu",
    class_name: "Uatu",
    repo: "almeidx/uatu",
    desc: "Observe cron jobs without replacing cron"
  },
  {
    name: "cerebro",
    class_name: "Cerebro",
    repo: "almeidx/cerebro",
    desc: "Manage and secure Linux servers over Tailscale SSH"
  }
].freeze

TARGETS = [
  {
    os: :macos,
    condition: "Hardware::CPU.arm?",
    triple: "aarch64-apple-darwin"
  },
  {
    os: :linux,
    condition: "Hardware::CPU.intel? && Hardware::CPU.is_64_bit?",
    triple: "x86_64-unknown-linux-musl"
  },
  {
    os: :linux,
    condition: "Hardware::CPU.arm? && Hardware::CPU.is_64_bit?",
    triple: "aarch64-unknown-linux-musl"
  }
].freeze

def gh_json(*args)
  stdout, status = Open3.capture2("gh", *args)
  abort "gh #{args.join(" ")} failed" unless status.success?

  JSON.parse(stdout)
end

def latest_release(repo)
  releases = gh_json("api", "repos/#{repo}/releases?per_page=20")
  release = releases.find { |candidate| !candidate.fetch("draft") }
  abort "No non-draft releases found for #{repo}" unless release

  release
end

def target_assets(project, release)
  version = release.fetch("tag_name").delete_prefix("v")
  prefix = "#{project.fetch(:name)}-#{version}-"
  assets = {}

  release.fetch("assets").each do |asset|
    name = asset.fetch("name")
    next unless name.start_with?(prefix) && name.end_with?(".tar.gz")

    triple = name.delete_prefix(prefix).delete_suffix(".tar.gz")
    digest = asset["digest"]&.delete_prefix("sha256:")
    abort "Missing SHA-256 digest for #{name}" unless digest

    assets[triple] = {
      url: asset.fetch("browser_download_url"),
      sha256: digest
    }
  end

  assets
end

def render_platform_block(os, targets, assets)
  available = targets.select { |target| assets.key?(target.fetch(:triple)) }
  return "" if available.empty?

  lines = ["  on_#{os} do"]
  available.each_with_index do |target, index|
    asset = assets.fetch(target.fetch(:triple))
    lines << "" if index.positive?
    lines << "    if #{target.fetch(:condition)}"
    lines << "      url #{asset.fetch(:url).inspect}"
    lines << "      sha256 #{asset.fetch(:sha256).inspect}"
    lines << "    end"
  end
  lines << "  end"
  lines.join("\n")
end

def render_formula(project, release)
  version = release.fetch("tag_name").delete_prefix("v")
  assets = target_assets(project, release)
  platform_blocks = %i[macos linux].map do |os|
    block = render_platform_block(os, TARGETS.select { |target| target.fetch(:os) == os }, assets)
    block.empty? ? nil : block
  end.compact

  abort "No supported release archives found for #{project.fetch(:repo)} #{release.fetch("tag_name")}" if platform_blocks.empty?

  <<~RUBY
    # frozen_string_literal: true

    # This file was generated by bin/update-formulae.
    class #{project.fetch(:class_name)} < Formula
      desc #{project.fetch(:desc).inspect}
      homepage "https://github.com/#{project.fetch(:repo)}"
      version #{version.inspect}
      license "Apache-2.0"

    #{platform_blocks.join("\n\n")}

      def install
        bin.install #{project.fetch(:name).inspect}
      end

      test do
        assert_match version.to_s, shell_output("\#{bin}/#{project.fetch(:name)} --version")
      end
    end
  RUBY
end

formula_dir = File.join(ROOT, "Formula")
FileUtils.mkdir_p(formula_dir)

PROJECTS.each do |project|
  release = latest_release(project.fetch(:repo))
  formula = render_formula(project, release)
  path = File.join(formula_dir, "#{project.fetch(:name)}.rb")
  File.write(path, formula)
  puts "Updated #{path} from #{project.fetch(:repo)} #{release.fetch("tag_name")}"
end
